#!/usr/bin/env bash

# Ensure the script exits immediately if any command fails
set -e

echo "
                      _ _ 
     /\              (_) |
    /  \   _ ____   ___| |
   / /\ \ | '_ \ \ / / | |
  / ____ \| | | \ V /| | |
 /_/    \_\_| |_|\_/ |_|_| 
 
 "

# Resolve the absolute path of this script file (handles symlinks safely)
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
    DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
cd "$DIR"

# Interactively setup .env if it is missing
if [ ! -f .env ]; then
    echo "⚠️  Configuration file (.env) not found."
    echo "Let's set up your local Anvil backend environment variables now."
    echo "------------------------------------------------------------"

    # 1. Host Storage Paths
    default_hf="$HOME/.cache/huggingface"
    read -p "Enter Hugging Face cache directory [$default_hf]: " hf_home
    hf_home="${hf_home:-$default_hf}"

    default_data="./"
    read -p "Enter local data storage directory [$default_data]: " data_dir
    data_dir="${data_dir:-$default_data}"

    # 2. Networking Ports
    default_llm_port="8000"
    read -p "Enter main LLM port [$default_llm_port]: " llm_port
    llm_port="${llm_port:-$default_llm_port}"

    # 3. GPU Device Allocation
    default_gpu0="0"
    read -p "Enter Generic LLM GPU Device ID 1 [$default_gpu0]: " llm_gpu0
    llm_gpu0="${llm_gpu0:-$default_gpu0}"

    default_gpu1="0"
    read -p "Enter Coder LLM GPU Device ID 1 [$default_gpu1]: " llm_gpu1
    llm_gpu1="${llm_gpu1:-$default_gpu1}"

    default_gpu2="1"
    read -p "Enter Coder LLM GPU Device ID 2 [$default_gpu2]: " llm_gpu2
    llm_gpu2="${llm_gpu2:-$default_gpu2}"

    default_idx_gpu="2"
    read -p "Enter Indexer GPU Device ID [$default_idx_gpu]: " idx_gpu
    idx_gpu="${idx_gpu:-$default_idx_gpu}"

    # Write configurations out to the new .env file
    cat << EOF > .env
# --- Host Storage Paths ---
HF_HOME=$hf_home
DATA_DIR=$data_dir

# --- Networking Ports ---
LLM_PORT=$llm_port

# --- GPU Device Allocation ---
LLM_DEVICE_ID_0=$llm_gpu0
LLM_DEVICE_ID_1=$llm_gpu1
LLM_DEVICE_ID_2=$llm_gpu2
INDEXER_STORAGE_DEVICE_ID=$idx_gpu
EOF

    echo "------------------------------------------------------------"
    echo "✅ Successfully generated your local .env configuration file!"
    echo ""
fi

# Extract variables from .env to use for local host curl checks
export $(grep -v '^#' .env | xargs)

desc_up="Start the Llama-Swap router and dependencies"
cmd_up() {
    echo "Starting the Anvil local backend cluster via Llama-Swap..."
    docker compose --profile coder up -d "$@"
}

desc_build="Force build/rebuild of custom configurations"
cmd_build() {
    echo "Rebuilding container configurations..."
    docker compose --profile coder build "$@"
}

desc_status="Verify active engine routing layers and API backends"
cmd_status() {
    echo "Llama-Swap Daemon & Infrastructure Status:"
    echo "------------------------------------------------------------"
    docker compose ps
    echo ""
    echo "Dynamic Model Routing Health Checks:"
    echo "------------------------------------------------------------"
    
    GATEWAY_PORT="${LLM_PORT:-8080}"
    
    # 1. Check if the central router gateway is alive
    if ! curl -s --max-time 2 "http://localhost:${GATEWAY_PORT}/v1/models" > /dev/null; then
        echo "🔴 Swap Router Gateway (Port ${GATEWAY_PORT}): OFFLINE (Service completely down)"
        echo "------------------------------------------------------------"
        return
    fi

    echo "🟢 Swap Router Gateway (Port ${GATEWAY_PORT}): ONLINE & ROUTING"
    echo "--- Registered Model Matrix ---"

    # 2. Get the list of ALL configured models from llama-swap
    models=$(curl -s --max-time 2 "http://localhost:${GATEWAY_PORT}/v1/models" | \
             grep -o '"id":[^,]*' | \
             sed 's/"id"://;s/"//g;s/ //g')

    # 3. Get the list of CURRENTLY active/loaded models from llama-swap's live state
    running_models=$(curl -s --max-time 2 "http://localhost:${GATEWAY_PORT}/running")

    if [ -z "$models" ]; then
        echo "⚠️  No models returned by the router gateway registry."
    else
        # 4. Loop through registered configurations and cross-reference with live running status
        echo "$models" | while read -r model_name; do
            if [ -z "$model_name" ]; then continue; fi

            if echo "$running_models" | grep -q "$model_name"; then
                printf "  \033[32m🟢\033[0m %-45s : ACTIVE & HOT\n" "$model_name"
            else
                printf "  \033[33m🟡\033[0m %-45s : COLD / SWAPPED OUT (Lazy-loads on demand)\n" "$model_name"
            fi
        done
    fi
    echo "------------------------------------------------------------"
}

desc_logs="Stream dynamic engine controller outputs"
cmd_logs() {
    echo "Streaming logs from your llama-swap orchestration engine..."
    docker compose --profile coder logs -f "$@"
}

desc_restart="Quickly cycle the core proxy daemon"
cmd_restart() {
    echo "Bouncing the llama-swap manager container..."
    docker compose --profile coder restart "$@"
}

desc_down="Stop all runtime services and child model processes"
cmd_down() {
    echo "🛑 Destroying active containers and runtime allocations..."
    docker compose --profile coder down "$@"
    # Safeguard clean up for orphaned on-demand vLLM instances spawned by llama-swap
    echo "🧹 Purging loose runtime on-demand models..."
    docker ps -a --filter "name=vllm-" -q | xargs -r docker stop | xargs -r docker rm || true
}

desc_setup_repo="Inject template configs, .roo frameworks, VS Code options, and rules into a target repo"
cmd_setup_repo() {
    local target_repo="$1"
    local config_template="$DIR/templates/zoo-code-settings.json.template"
    local mcp_template="$DIR/templates/mcp.json.template"
    local extensions_template="$DIR/templates/extensions.json.template"
    local roo_rules_source="$DIR/templates/update_roo_rules.md"
    local roo_template_source="$DIR/templates/roo_template"
    
    # 1. Verification and validation safeguards
    if [ -z "$target_repo" ]; then
        echo "❌ Error: Please provide the target repository directory path."
        echo "Usage: ./anvil setup-repo /path/to/your/repo"
        exit 1
    fi

    if [ ! -d "$target_repo" ]; then
        echo "❌ Error: Target directory '$target_repo' does not exist."
        exit 1
    fi

    if [ ! -f "$config_template" ]; then
        echo "❌ Error: Core settings template not found at '$config_template'."
        exit 1
    fi

    if [ ! -f "$mcp_template" ]; then
        echo "❌ Error: MCP context template file not found at '$mcp_template'."
        exit 1
    fi

    if [ ! -f "$extensions_template" ]; then
        echo "❌ Error: Extensions template file not found at '$extensions_template'."
        exit 1
    fi

    if [ ! -f "$roo_rules_source" ]; then
        echo "❌ Error: Roo rules command file not found at '$roo_rules_source'."
        exit 1
    fi

    if [ ! -d "$roo_template_source" ]; then
        echo "❌ Error: Roo template directory not found at '$roo_template_source'."
        exit 1
    fi

    # Resolve absolute path natively to prevent relative resolution leakage
    local abs_target_repo
    abs_target_repo=$(cd "$target_repo" && pwd)

    # 2. Inject unified layout configuration pointing everything directly to the unified llama-swap gateway port
    local current_gateway_port="${LLM_PORT:-8080}"

    # Context window for the coder model - extracted from config.yaml (single source of truth)
    local context_window
    context_window=$(grep -A50 "^  \"Qwen/Qwen3.6-35B-A3B-FP8\":" config.yaml | grep -- '--max-model-len' | awk '{print $NF}' | head -1)
    context_window="${context_window:-262144}"

    echo "⚙️  Generating zoo-code-settings.json unified across a single proxy gate..."
    echo "   ↳ 📐 Context window: ${context_window}"
    sed -e "s/\${LLM_PORT}/${current_gateway_port}/g" \
        -e "s/\${CONTEXT_WINDOW}/${context_window}/g" \
        "$config_template" > "$abs_target_repo/zoo-code-settings.json"
    echo "   ↳ ✅ Injected: $abs_target_repo/zoo-code-settings.json"

    # 3. Dynamic verification and structural setup for the .roo ecosystem
    echo "📂 Verifying framework directory architectures..."
    local sub_dirs=(".roo" ".roo/commands" ".roo/skills" ".roo/rules")
    for dir in "${sub_dirs[@]}"; do
        if [ ! -d "$abs_target_repo/$dir" ]; then
            echo "   ↳ 📁 Creating missing directory: $dir"
            mkdir -p "$abs_target_repo/$dir"
        fi
    done

    # 4. GitHub Context Interactive Provisioning Step
    local github_token=""
    echo ""
    read -p "❓ Do you use GitHub and want to map a personal repository token for the agent? (y/N): " use_github
    echo ""

    if [[ "$use_github" =~ ^[Yy](es)?$ ]]; then
        read -r -p "🔑 Enter your GitHub Personal Access Token: " github_token
        echo "⚡ Token accepted."
    else
        echo "⚠️  Skipping interactive GitHub integration token."
        echo "💡 Note: If you wish to set this up later, you must manually edit the"
        echo "   'mcp.json' configuration file inside your repository's '.roo/' directory"
        echo "   and populate the GITHUB_TOKEN variable to allow the agent to access GitHub APIs."
    fi
    echo ""

    # 5. Populate and deploy mcp.json context using pipeline delimiters
    echo "⚙️  Processing MCP context mappings and injecting into workspace..."
    sed -e "s|\${workspaceFolder}|${abs_target_repo}|g" \
        -e "s|\${GITHUB_TOKEN}|${github_token}|g" \
        "$mcp_template" > "$abs_target_repo/.roo/mcp.json"
    echo "   ↳ ✅ Instantiated: $abs_target_repo/.roo/mcp.json"

    # 6. Verify and set up .vscode configuration space
    echo "💻 Verifying IDE configuration space..."
    if [ ! -d "$abs_target_repo/.vscode" ]; then
        echo "   ↳ 📁 Creating missing directory: .vscode"
        mkdir -p "$abs_target_repo/.vscode"
    fi
    cp "$extensions_template" "$abs_target_repo/.vscode/extensions.json"
    echo "   ↳ ✅ Injected: $abs_target_repo/.vscode/extensions.json"

    # 7. Provision the custom rule automation utility
    echo "🛠️  Deploying core orchestration instructions..."
    cp "$roo_rules_source" "$abs_target_repo/.roo/commands/update_roo_rules.md"
    echo "   ↳ ✅ Injected: $abs_target_repo/.roo/commands/update_roo_rules.md"

    # 7.5. Copy roo_template folder to root repository as is
    echo "📦 Copying roo_template directory to repository root..."
    cp -r "$roo_template_source" "$abs_target_repo/"
    echo "   ↳ ✅ Copied: $abs_target_repo/roo_template"

    # 8. Final wrap up and output instructions
    echo ""
    echo "✨ Workspace setup complete for: $abs_target_repo"
    echo "----------------------------------------------------------------------"
    echo "👉 IMPORTANT NEXT STEP:"
    echo "To update the various rules of the LLM model, open your Zoo chat"
    echo "interface with the LLM and instruct it to execute the command /update_roo_rules.md"
    echo "----------------------------------------------------------------------"
}

desc_help="Display this help menu"
cmd_help() {
    echo "Usage: ./anvil [command] [options]"
    echo ""
    echo "Available Commands:"
    echo "------------------------------------------------------------"
    
    # Dynamically scan this source file to find all defined cmd_ functions in order
    grep -E '^cmd_[a-zA-Z0-9_-]+\(\)' "$SOURCE" | while read -r line; do
        func_name=$(echo "$line" | cut -d'(' -f1)
        cmd_name="${func_name#cmd_}"
        
        # Use indirect expansion to pull the matching description text
        desc_var="desc_${cmd_name}"
        desc="${!desc_var}"
        
        printf "  %-8s : %s\n" "$cmd_name" "$desc"
    done
    echo "------------------------------------------------------------"
}


# ==============================================================================
# AUTOMATIC EXECUTION ROUTER
# ==============================================================================

# Parse target command name (defaults to help if empty)
cmd="${1:-help}"

# Safely shift arguments if an option was supplied
if [ $# -gt 0 ]; then
    shift
fi

# Verify if a corresponding function exists in shell memory
if declare -F "cmd_$cmd" > /dev/null; then
    "cmd_$cmd" "$@"
else
    echo "❌ Unknown command: '$cmd'"
    echo ""
    cmd_help
    exit 1
fi